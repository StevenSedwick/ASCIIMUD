# Copy to .env (gitignored) and fill in.

# Twitch chat (use a SEPARATE bot account, not the broadcaster)
TWITCH_BOT_NICK=your_bot_account
TWITCH_BOT_TOKEN=oauth:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITCH_CHANNEL=your_channel_login_lowercase
TWITCH_BROADCASTER_LOGIN=your_channel_login_lowercase
BROADCASTER_DISPLAY_NAME=Steven

# ASCIIMUD companion WebSocket
COMPANION_WS_URL=ws://127.0.0.1:8765/ws

# AI rewrite (optional). Set AI_ENABLED=false to disable entirely.
AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_MAX_CHARS=450
AI_TIMEOUT_SECONDS=4

# ASCIIMUD overlay addon link the bot will share via !addon and periodic promo
ADDON_URL=https://www.curseforge.com/wow/addons/textadventure
# Seconds between automatic addon promo posts. 0 disables the auto-post.
ADDON_PROMO_INTERVAL=1500

# Live map page — viewers open this for a live dot on the zone map
# Format: https://<ebs-worker>.workers.dev/map/<channel_id>
MAP_URL=https://asciimud-ebs.goreakis2.workers.dev/map/1486940269

# Logging
LOG_LEVEL=INFO
INTERFACE_URL=https://asciimud-ebs.goreakis2.workers.dev/interface/1486940269
